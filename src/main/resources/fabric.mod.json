{
  "schemaVersion": 1,
  "id": "default_commands",
  "version": "${version}",
  "name": "Default commands",
  "description": "Runs configurable default commands on world creation and player join, or server startup.",
  "authors": [],
  "contact": {},
  "license": "MIT",
  "icon": "assets/default_commands/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "b4.default_commands.client.Default_commandsDataGenerator"
    ],
    "client": [
      "b4.default_commands.client.Default_commandsClient"
    ],
    "modmenu": [
      "b4.default_commands.client.DefaultCommandsModMenu"
    ],
    "main": [
      "b4.default_commands.Default_commands"
    ]
  },
  "mixins": [
    "default_commands.mixins.json",
    {
      "config": "default_commands.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
